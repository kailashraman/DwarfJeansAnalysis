# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/
*.so
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/

# Data files (large/generated)
*.fits
*.hdf5
*.h5
*.npy
*.npz
*.pkl
*.pickle
# Tracked exceptions: small input binaries under data/
!data/**/*.npz
!data/**/*.npy
!data/**/*.fits
!data/**/*.pkl

# Images and PDFs
*.png
*.jpg
*.jpeg
*.svg
*.gif
*.pdf
# Writeup PDFs are committed (locally compiled from docs/writeup/*.tex)
!docs/writeup/*.pdf

# Outputs / chains
outputs/
chains/
# results/ is mostly gitignored; allow only the audits subtree + Zenodo README
results/*
!results/audits/
!results/production/
results/production/*
!results/production/README.md

# LaTeX build artifacts
*.aux
*.log
*.out
*.synctex.gz
*.fls
*.fdb_latexmk
*.bbl
*.blg
*.toc

# OS
.DS_Store
*.swp
*~

# Claude Code local state
.claude/

# SLURM logs and per-run keyfiles
logs/

# Local sanity-check scripts and figures
scratch/

